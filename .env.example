# Max size of a single uploaded file, in MB. 4096 = 4GB (fits most Minecraft
# worlds). Raise as needed.
SEND_MAX_FILE_MB=4096

# Max total bytes held on disk across all live drops, in MB. Uploads are
# rejected (HTTP 507) once this is reached until drops expire or are claimed.
# IMPORTANT: keep this comfortably below your server's free disk space — check
# with `df -h`. This is your real guard against filling the drive.
SEND_MAX_TOTAL_MB=20480

# Hard ceiling on the max_reads a sender can request.
SEND_MAX_READS=20
